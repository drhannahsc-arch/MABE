+"""
+glycan/inverse_design.py — MABE Glycan Inverse Design Engine (v2)
+
+Given a target sugar, enumerates receptor pocket configurations and ranks
+by selectivity over interferents.
+
+Selectivity mechanism (position-specific):
+  Each carbon presents a fixed OH type for each sugar (axial, equatorial,
+  primary, NHAc, absent). A pocket specifies which positions it contacts.
+  Desolv penalty is position- and sugar-specific, so different sugars
+  score differently against the same pocket.
+
+  Example: pocket contacts {C4}
+    Glc: C4=K_EQ → desolv=+2.4  (equatorial, low penalty)
+    Gal: C4=K_AX → desolv=+6.3  (axial, high penalty → Gal disfavored)
+    → gap = Glc_dG - Gal_dG = -3.9 kJ/mol  (pocket selects Glc over Gal)
+
+Position-specific OH types (4C1 chair conformation):
+  Glc:    C1:EQ  C2:EQ  C3:EQ  C4:EQ  C6:C6
+  Gal:    C1:EQ  C2:EQ  C3:EQ  C4:AX  C6:C6
+  Man:    C1:EQ  C2:AX  C3:EQ  C4:EQ  C6:C6
+  GlcNAc: C1:EQ  C2:NAC C3:EQ  C4:EQ  C6:C6
+  GalNAc: C1:EQ  C2:NAC C3:EQ  C4:AX  C6:C6
+  2dGlc:  C1:EQ  C2:--  C3:EQ  C4:EQ  C6:C6  [C2-OH absent]
+  Fru:    C2:EQ  C3:EQ  C4:AX  C5:C6         [furanose]
+  Xyl:    C1:EQ  C2:EQ  C3:EQ  C4:AX         [no C6]
+  Fuc:    C1:EQ  C2:AX  C3:EQ  C4:EQ         [no C6; L-fucose]
+
+Parameters: v2.3 locked (glycan/parameters_v23.py)
+"""
+
+from dataclasses import dataclass
+from itertools import combinations
+from typing import Optional
+
+from glycan.parameters_v23 import EPS_HB_EFF, CH_PI_EPS, K_DESOLV, EPS_LINKER_NET
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Sugar position maps
+# ══════════════════════════════════════════════════════════════════════════
+
+SUGAR_POSITIONS = {
+    "Glc":    {"C1":"K_EQ","C2":"K_EQ","C3":"K_EQ","C4":"K_EQ","C6":"K_C6"},
+    "Gal":    {"C1":"K_EQ","C2":"K_EQ","C3":"K_EQ","C4":"K_AX","C6":"K_C6"},
+    "Man":    {"C1":"K_EQ","C2":"K_AX","C3":"K_EQ","C4":"K_EQ","C6":"K_C6"},
+    "GlcNAc": {"C1":"K_EQ","C2":"K_NAC","C3":"K_EQ","C4":"K_EQ","C6":"K_C6"},
+    "GalNAc": {"C1":"K_EQ","C2":"K_NAC","C3":"K_EQ","C4":"K_AX","C6":"K_C6"},
+    "2dGlc":  {"C1":"K_EQ","C3":"K_EQ","C4":"K_EQ","C6":"K_C6"},
+    "Fru":    {"C2":"K_EQ","C3":"K_EQ","C4":"K_AX","C5":"K_C6"},
+    "Xyl":    {"C1":"K_EQ","C2":"K_EQ","C3":"K_EQ","C4":"K_AX"},
+    "Fuc":    {"C1":"K_EQ","C2":"K_AX","C3":"K_EQ","C4":"K_EQ"},
+}
+
+# CH-pi contacts: axial H's on beta-face from equatorial-OH carbons
+# Axial-OH carbons block the face; absent carbons don't block.
+def _max_chp(sugar: str) -> int:
+    pos = SUGAR_POSITIONS.get(sugar, {})
+    return sum(1 for t in pos.values() if t == "K_EQ")
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Archetype suggestions
+# ══════════════════════════════════════════════════════════════════════════
+
+ARCHETYPE_LIBRARY = [
+    {
+        "name": "Davis GluHUT (anthracene TEM + urea array)",
+        "res_types": ["anthracene"],
+        "n_CHP_range": (2, 3), "n_HB_range": (3, 5),
+        "ref": "Eades et al. 2026 ChemRxiv; Davis 2012 Nat.Chem. 4:718",
+        "notes": "Preorganized urea H-bond donors; anthracene beta-face stacking",
+    },
+    {
+        "name": "Tryptophan-lined cavity",
+        "res_types": ["Trp"],
+        "n_CHP_range": (1, 3), "n_HB_range": (2, 5),
+        "ref": "Stoddart cage JACS 2021 143:15688",
+        "notes": "Indole CH-pi; amide/urea H-bond donors",
+    },
+    {
+        "name": "Phenyl/Tyr cleft",
+        "res_types": ["Tyr", "Phe"],
+        "n_CHP_range": (1, 2), "n_HB_range": (2, 4),
+        "ref": "Asensio 2013 Acc.Chem.Res. 46:946",
+        "notes": "Phenol/phenyl CH-pi; Ser/Thr H-bond donors",
+    },
+    {
+        "name": "Pure H-bond array (no aromatic platform)",
+        "res_types": ["none"],
+        "n_CHP_range": (0, 0), "n_HB_range": (3, 6),
+        "ref": "Clarke 2001; designed H-bond networks",
+        "notes": "Selectivity via position-specific desolv differences",
+    },
+    {
+        "name": "Macrocyclic cage (aromatic + H-bond)",
+        "res_types": ["anthracene", "Tyr", "Phe"],
+        "n_CHP_range": (1, 3), "n_HB_range": (2, 4),
+        "ref": "Stoddart PCage JACS 2021 143:15688",
+        "notes": "Preorganized cavity; CH-pi + directional HBs",
+    },
+]
+
+
+def _suggest_archetype(res_type: str, n_CHP: int, n_HB: int) -> Optional[dict]:
+    for arch in ARCHETYPE_LIBRARY:
+        if res_type not in arch["res_types"]:
+            continue
+        cmin, cmax = arch["n_CHP_range"]
+        hmin, hmax = arch["n_HB_range"]
+        if cmin <= n_CHP <= cmax and hmin <= n_HB <= hmax:
+            return arch
+    return None
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Pocket config & result
+# ══════════════════════════════════════════════════════════════════════════
+
+@dataclass
+class PocketConfig:
+    contacted_positions: tuple
+    n_HB: int
+    n_CHP: int
+    res_type: str
+    n_linker: int = 0
+    archetype: Optional[str] = None
+    archetype_ref: Optional[str] = None
+    archetype_notes: Optional[str] = None
+
+    @property
+    def pocket_spec(self) -> str:
+        lines = [
+            f"  Positions: {', '.join(self.contacted_positions)}",
+            f"  H-bonds:   {self.n_HB}",
+            f"  CH-π:      {self.n_CHP} × {self.res_type}",
+        ]
+        if self.archetype:
+            lines.append(f"  Archetype: {self.archetype}")
+        if self.archetype_ref:
+            lines.append(f"  Ref:       {self.archetype_ref}")
+        return "\n".join(lines)
+
+
+@dataclass
+class InverseDesignResult:
+    target: str
+    pocket: PocketConfig
+    dG_physics_target: float
+    interferent_dG: dict
+    selectivity_gaps: dict
+    min_gap: float
+    worst_interferent: str
+    selectivity_grade: str
+    rank: int = 0
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Scoring
+# ══════════════════════════════════════════════════════════════════════════
+
+def _score_pocket_sugar(pocket: PocketConfig, sugar: str) -> Optional[float]:
+    pos_map = SUGAR_POSITIONS.get(sugar)
+    if pos_map is None:
+        return None
+
+    desolv = 0.0
+    n_contactable = 0
+    for pos in pocket.contacted_positions:
+        oh_type = pos_map.get(pos)
+        if oh_type is None:
+            return None          # Sugar missing this carbon
+        desolv += K_DESOLV.get(oh_type, 0.0)
+        n_contactable += 1
+
+    if pocket.n_HB > n_contactable:
+        return None
+    if pocket.n_CHP > _max_chp(sugar):
+        return None
+
+    return (pocket.n_HB * EPS_HB_EFF
+            + desolv
+            + pocket.n_CHP * CH_PI_EPS.get(pocket.res_type, 0.0)
+            + pocket.n_linker * EPS_LINKER_NET)
+
+
+def _grade(min_gap: float) -> str:
+    if min_gap <= -5.0: return "A"
+    if min_gap <= -3.0: return "B"
+    if min_gap <= -1.0: return "C"
+    if min_gap < 0.0:   return "D"
+    return "F"
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Enumeration + design
+# ══════════════════════════════════════════════════════════════════════════
+
+def design_glycan_pocket(
+    target: str,
+    interferents: Optional[list[str]] = None,
+    top_n: int = 10,
+    max_enumerate: int = 5000,
+    require_grade: Optional[str] = None,
+    min_n_contacts: int = 2,
+) -> list[InverseDesignResult]:
+    """Design receptor pocket for selective binding of target sugar."""
+    if target not in SUGAR_POSITIONS:
+        raise ValueError(f"Unknown sugar '{target}'. Available: {sorted(SUGAR_POSITIONS.keys())}")
+
+    if interferents is None:
+        interferents = [s for s in SUGAR_POSITIONS if s != target]
+
+    pos_map = SUGAR_POSITIONS[target]
+    target_positions = sorted(pos_map.keys())
+    max_chp_target = _max_chp(target)
+    res_types = list(CH_PI_EPS.keys())
+
+    results = []
+    seen = set()
+    n_enumerated = 0
+
+    for n_pos in range(min_n_contacts, len(target_positions) + 1):
+        for pos_combo in combinations(target_positions, n_pos):
+            for res_type in res_types:
+                for n_CHP in range(0, min(max_chp_target, 3) + 1):
+                    if n_CHP > 0 and res_type == "none":
+                        continue
+                    for n_HB in range(0, n_pos + 1):
+                        sig = (pos_combo, n_HB, n_CHP, res_type)
+                        if sig in seen:
+                            continue
+                        seen.add(sig)
+                        n_enumerated += 1
+                        if n_enumerated > max_enumerate:
+                            break
+
+                        arch = _suggest_archetype(res_type, n_CHP, n_HB)
+                        pocket = PocketConfig(
+                            contacted_positions=pos_combo,
+                            n_HB=n_HB, n_CHP=n_CHP, res_type=res_type,
+                            archetype=arch["name"] if arch else None,
+                            archetype_ref=arch["ref"] if arch else None,
+                            archetype_notes=arch["notes"] if arch else None,
+                        )
+
+                        target_dG = _score_pocket_sugar(pocket, target)
+                        if target_dG is None:
+                            continue
+
+                        intf_dG = {}
+                        for intf in interferents:
+                            dg = _score_pocket_sugar(pocket, intf)
+                            intf_dG[intf] = dg if dg is not None else 99.0
+
+                        gaps = {intf: target_dG - dg for intf, dg in intf_dG.items()}
+                        min_gap = min(gaps.values())
+                        worst = min(gaps, key=lambda k: gaps[k])
+                        grade = _grade(min_gap)
+
+                        if require_grade:
+                            grade_order = ["A", "B", "C", "D", "F"]
+                            if grade_order.index(grade) > grade_order.index(require_grade):
+                                continue
+
+                        results.append(InverseDesignResult(
+                            target=target, pocket=pocket,
+                            dG_physics_target=round(target_dG, 3),
+                            interferent_dG={k: round(v, 3) for k, v in intf_dG.items() if v < 90},
+                            selectivity_gaps={k: round(v, 3) for k, v in gaps.items()},
+                            min_gap=round(min_gap, 3),
+                            worst_interferent=worst,
+                            selectivity_grade=grade,
+                        ))
+
+    results.sort(key=lambda r: (r.min_gap, r.dG_physics_target))
+    for i, r in enumerate(results):
+        r.rank = i + 1
+
+    return results[:top_n]
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Pretty print
+# ══════════════════════════════════════════════════════════════════════════
+
+def print_design_results(results: list[InverseDesignResult], verbose: bool = True):
+    if not results:
+        print("  No viable designs found."); return
+
+    target = results[0].target
+    print(f"\n  ╔═══════════════════════════════════════════════════════════════╗")
+    print(f"  ║  MABE GLYCAN INVERSE DESIGN — Target: {target:<25s}║")
+    print(f"  ║  v2.3 locked parameters | Zero biological fitting            ║")
+    print(f"  ╚═══════════════════════════════════════════════════════════════╝")
+
+    for r in results:
+        print(f"\n  Rank {r.rank:2d} [{r.selectivity_grade}]  "
+              f"gap={r.min_gap:+.2f} kJ/mol vs {r.worst_interferent}")
+        print(f"  ─────────────────────────────────────────────────────────")
+        print(r.pocket.pocket_spec)
+        print(f"  ΔG_phys(target): {r.dG_physics_target:+.2f} kJ/mol (excl. DG0)")
+        if verbose:
+            print(f"  Selectivity gaps:")
+            for intf, gap in sorted(r.selectivity_gaps.items(), key=lambda x: x[1]):
+                if abs(gap) > 90:
+                    continue
+                bar = "▓" * max(0, int(-gap/0.5)) if gap < 0 else "░" * min(10, int(gap/0.5))
+                flag = "✓" if gap < -1.0 else ("~" if gap < 0 else "✗")
+                print(f"    vs {intf:10s}: {gap:+6.2f} kJ/mol  {bar} {flag}")
-- 
2.43.0