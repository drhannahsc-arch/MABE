+class TestCrowdingDistance:
+
+    def test_two_members_both_inf(self):
+        """Front with 2 members → both get infinite distance."""
+        vecs = [(10, 5), (5, 10)]
+        cd = crowding_distance([0, 1], vecs)
+        assert cd[0] == float('inf')
