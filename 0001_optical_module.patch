+"""
+optical/photonic_glass.py — Module 6: Photonic Glass Forward Model
+
+Single-scattering model for disordered colloidal film reflectance.
+
+R(λ) ∝ C_back(λ) × S(q_back, λ)
+
+where:
+  q_back = 4π n_eff(λ) / λ    (backscattering wavevector in effective medium)
+  n_eff  = volume-average effective index of sphere+medium composite
+  C_back = (π/4) D² × Q_back  (single-particle backscattering cross-section)
+  S(q)   = Percus-Yevick structure factor (Module 5)
+
+n_eff accounts for both the sphere material and the medium:
+  n_eff² = φ × n_sphere² + (1-φ) × n_medium²   (volume average)
+
+Absorber modelled as imaginary part added to n_eff via Maxwell-Garnett
+mixing of absorber into the medium fraction.
+
+References:
+  Magkiriadou 2014 Phys. Rev. E 90:062302
+  Manoharan structural-color package (github.com/manoharan-lab/structural-color)
+  Hwang et al. 2021 PNAS 118:e2021227118
+"""
+
+import math
+import numpy as np
+
+from optical.refractive_index import n_complex, n_real
+from optical.mie_scattering import mie_efficiencies
+from optical.structure_factor import structure_factor_PY
+
+
+def _n_eff_composite(n_sphere: float, n_medium: float,
+                     packing_fraction: float) -> float:
+    """Volume-average effective refractive index for sphere+medium composite."""
+    return math.sqrt(packing_fraction * n_sphere**2
+                     + (1 - packing_fraction) * n_medium**2)
+
+
+def _mg_absorber_k(n_medium: float, n_abs_k: float,
+                   f_abs: float) -> float:
+    """Effective extinction k from Maxwell-Garnett mixing of absorber into medium.
+
+    For small f_abs: k_eff ≈ f_abs × k_absorber × 3n_medium² / (n_abs² + 2n_medium²)
+    """
+    n_abs_n = 2.0   # carbon n ≈ 2.0
+    eps_m = n_medium**2
+    eps_i = complex(n_abs_n**2 - n_abs_k**2, 2*n_abs_n*n_abs_k)
+    numerator   = f_abs * (eps_i - eps_m)
+    denominator = eps_m + (1 - f_abs) * (eps_i - eps_m) / 3
+    k_eff = abs((3 * eps_m * numerator / (3*eps_m + denominator)).imag) ** 0.5
+    return k_eff * 0.1   # approximate; keep small for single-scatter regime
+
+
+def photonic_glass_reflectance(
+    diameter_nm: float,
+    sphere_material: str,
+    n_medium_base: float,
+    packing_fraction: float,
+    wavelengths_nm: np.ndarray,
+    absorber_material: str = "carbon",
+    absorber_fraction: float = 0.0,
+) -> np.ndarray:
+    """Compute relative reflectance spectrum of a photonic glass film.
+
+    Returns R(λ) array, normalised to max = 1.
+    """
+    R = np.zeros(len(wavelengths_nm))
+
+    for i, lam in enumerate(wavelengths_nm):
+        n_sph = n_real(sphere_material, lam)
+
+        # Effective medium: sphere + medium composite (sets q_back)
+        n_eff = _n_eff_composite(n_sph, n_medium_base, packing_fraction)
+
+        # Backscattering wavevector in effective medium
+        q_back = 4 * math.pi * n_eff / lam
+
+        # Structure factor at q_back
+        Sq = structure_factor_PY(q_back, diameter_nm, packing_fraction)
+
+        # Mie backscattering cross-section (sphere in effective medium)
+        n_sph_c = n_complex(sphere_material, lam)
+        mie = mie_efficiencies(diameter_nm, n_sph_c, n_eff, lam)
+        Qback = mie["Q_back"]
+        C_back = (math.pi / 4) * diameter_nm**2 * Qback
+
+        # Absorber attenuation (Beer-Lambert, film thickness ~10D)
+        k_abs = 0.0
+        if absorber_fraction > 0:
+            n_abs_c = n_complex(absorber_material, lam)
+            k_abs = absorber_fraction * n_abs_c.imag
+        L_nm = 10 * diameter_nm
+        attenuation = math.exp(-4 * math.pi * k_abs * L_nm / lam)
+
+        R[i] = C_back * Sq * attenuation
+
+    Rmax = R.max()
+    return R / Rmax if Rmax > 0 else R
+
+
+def photonic_glass_peak_wavelength(
+    diameter_nm: float,
+    sphere_material: str,
+    n_medium: float,
+    packing_fraction: float,
+    wl_range: tuple = (380, 780),
+    n_points: int = 300,
+) -> float:
+    """Return predicted peak reflectance wavelength (nm)."""
+    wls = np.linspace(wl_range[0], wl_range[1], n_points)
+    R   = photonic_glass_reflectance(diameter_nm, sphere_material, n_medium,
+                                      packing_fraction, wls)
+    return float(wls[np.argmax(R)])
+
+
+# Magkiriadou 2014, Phys. Rev. E 90:062302 — PS photonic glasses, φ ≈ 0.55
+# Peak wavelengths from Fig. 2 and Table 1 (Harvard DASH thesis version)
+MAGKIRIADOU_DATA = [
+    (172, 440, "blue"),
+    (195, 490, "cyan"),
+    (220, 530, "green"),
+    (250, 580, "yellow-green"),
+    (270, 610, "orange"),
+    (300, 640, "desaturated — red problem"),
+]
