+"""
+optical/refractive_index.py — Module 1: Refractive Index Database
+
+Provides n(λ) + k(λ) for optical materials via Sellmeier or Cauchy
+equations hardcoded from primary literature sources.
+
+Function signature: n_complex(material, wavelength_nm) → complex
+  Real part: refractive index n
+  Imaginary part: extinction coefficient k (absorption; positive = absorbing)
+
+Sources (all Tier 1 or Tier 2 per META2026_Code_Validation_Checklist):
+  SiO₂:        Malitson 1965, J. Opt. Soc. Am. 55:1205
+  TiO₂ rutile: Devore 1951, J. Opt. Soc. Am. 41:416 (ordinary ray)
+  TiO₂ anatase: Sellmeier fit from Ribarsky 1982 (Palik vol 1)
+  Polystyrene:  Sultanova 2009, Acta Phys. Pol. A 116:585
+  ZnO:          Bond 1965, J. Appl. Phys. 36:1674
+  Si₃N₄:       Luke 2015, Opt. Lett. 40:4823
+  Fe₂O₃:       Querry 1985 (Palik vol 2 compilation) — k from Palik
+  Carbon (amorph): Palik vol 2 (Jellison 1992 / Wemple approach)
+  Gold:         Johnson & Christy 1972, Phys. Rev. B 6:4370
+  Aluminum:     Palik vol 1 (Shiles 1980)
+  Water:        Hale & Querry 1973, Appl. Opt. 12:555
+  Air:          n = 1.0003 (non-dispersive, vacuum = 1.0)
+  Polydopamine: Mrózek 2022 (approximate; n ≈ 1.65–1.68 weak dispersion)
+
+All Sellmeier equations in the form:
+  n²(λ) = 1 + Σ_i [B_i × λ² / (λ² - C_i)]
+where λ is in micrometers.
+"""
+
+import math
+from typing import Union
+
+import numpy as np
+
+# ══════════════════════════════════════════════════════════════════════════
+# Sellmeier coefficient tables
+# Units: λ in micrometers in all formulas
+# ══════════════════════════════════════════════════════════════════════════
+
+# SiO₂ — Malitson 1965 (fused silica, 0.21–6.7 μm)
+_SIO2_SELLMEIER = [
+    (0.6961663, 0.0684043**2),
+    (0.4079426, 0.1162414**2),
+    (0.8974794, 9.896161**2),
+]
+
+# TiO₂ rutile (ordinary ray) — Devore 1951, J. Opt. Soc. Am. 41:416
+# Direct tabulation; interpolated at runtime. Palik vol 1 p.795 cross-check.
+_TIO2_RUTILE_TAB = [
+    (430, 2.856), (450, 2.800), (460, 2.777), (470, 2.757),
+    (480, 2.739), (490, 2.724), (500, 2.713), (510, 2.700),
+    (520, 2.689), (530, 2.679), (540, 2.669), (550, 2.659),
+    (560, 2.650), (570, 2.641), (580, 2.633), (589, 2.614),
+    (600, 2.616), (620, 2.600), (650, 2.583), (700, 2.562),
+    (750, 2.548), (800, 2.533), (900, 2.511), (1000, 2.484),
+]
+
+# Polystyrene — Sultanova 2009 (0.436–1.052 μm)
+_PS_SELLMEIER = [
