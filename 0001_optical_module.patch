+    (330.0, 0.95, 2.66), (340.0, 0.91, 2.68), (350.0, 0.87, 2.69),
+    (360.0, 0.83, 2.70), (370.0, 0.79, 2.70), (380.0, 0.75, 2.69),
+    (390.0, 0.71, 2.68), (400.0, 0.67, 2.67), (410.0, 0.63, 2.67),
+    (420.0, 0.60, 2.68), (430.0, 0.57, 2.68), (440.0, 0.54, 2.68),
+    (450.0, 0.52, 2.69), (460.0, 0.50, 2.71), (470.0, 0.48, 2.73),
