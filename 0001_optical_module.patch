+_CMF_WLS  = np.array([r[0] for r in _CIE_CMF_5NM])
+_CMF_XBAR = np.array([r[1] for r in _CIE_CMF_5NM])
+_CMF_YBAR = np.array([r[2] for r in _CIE_CMF_5NM])
