+def spectrum_to_XYZ(R_lambda: np.ndarray, wavelengths_nm: np.ndarray,
+                     illuminant: str = "D65") -> tuple:
+    """Convert reflectance spectrum to CIE 1931 XYZ tristimulus values.
+
+    Args:
+        R_lambda:       Reflectance array (0–1), same length as wavelengths_nm
+        wavelengths_nm: Wavelength array in nm
+        illuminant:     'D65' (only option currently)
+
+    Returns:
+        (X, Y, Z) floats
+    """
+    if illuminant.upper() != "D65":
+        raise NotImplementedError("Only D65 supported")
+
+    xbar, ybar, zbar = _interp_cmf(wavelengths_nm)
+    illum = _interp_d65(wavelengths_nm)
+
+    dw = np.gradient(wavelengths_nm)   # non-uniform spacing handled
+    k_norm = np.sum(ybar * illum * dw)
+
+    X = np.sum(R_lambda * xbar * illum * dw) / k_norm
+    Y = np.sum(R_lambda * ybar * illum * dw) / k_norm
+    Z = np.sum(R_lambda * zbar * illum * dw) / k_norm
+
+    return float(X), float(Y), float(Z)
+
+
+def XYZ_to_xyY(X: float, Y: float, Z: float) -> tuple:
+    """CIE 1931 chromaticity coordinates."""
+    denom = X + Y + Z
+    if denom < 1e-10:
+        return (0.3127, 0.3290, 0.0)   # D65 white point as default
+    return (X / denom, Y / denom, Y)
+
+
+def XYZ_to_sRGB(X: float, Y: float, Z: float) -> tuple:
+    """Convert XYZ to sRGB (0–255 integers, D65 white point).
+
+    Using IEC 61966-2-1:1999 matrix and gamma.
+    """
+    # Linear sRGB from XYZ (D65)
+    r_lin =  3.2406*X - 1.5372*Y - 0.4986*Z
+    g_lin = -0.9689*X + 1.8758*Y + 0.0415*Z
+    b_lin =  0.0557*X - 0.2040*Y + 1.0570*Z
+
+    def _gamma(c: float) -> float:
+        if c <= 0.0031308:
+            return 12.92 * c
+        return 1.055 * c**(1/2.4) - 0.055
+
+    r = _gamma(max(0.0, r_lin))
+    g = _gamma(max(0.0, g_lin))
+    b = _gamma(max(0.0, b_lin))
+
+    return (min(255, int(r * 255 + 0.5)),
+            min(255, int(g * 255 + 0.5)),
+            min(255, int(b * 255 + 0.5)))
+
+
+def XYZ_to_Lab(X: float, Y: float, Z: float) -> tuple:
+    """Convert XYZ to CIE L*a*b* (D65 reference white)."""
+    # D65 reference white
+    Xn, Yn, Zn = 0.95047, 1.00000, 1.08883
+
+    def _f(t: float) -> float:
+        if t > 0.008856:
+            return t**(1/3)
+        return 7.787 * t + 16/116
+
+    fx = _f(X / Xn)
+    fy = _f(Y / Yn)
+    fz = _f(Z / Zn)
+
+    L = 116 * fy - 16
+    a = 500 * (fx - fy)
+    b = 200 * (fy - fz)
+    return (L, a, b)
+
+
+def cie_delta_E(Lab1: tuple, Lab2: tuple) -> float:
+    """CIE76 color difference ΔE between two Lab colors."""
+    return math.sqrt(sum((a - b)**2 for a, b in zip(Lab1, Lab2)))
+
+
+def spectrum_to_color(R_lambda: np.ndarray, wavelengths_nm: np.ndarray,
+                       illuminant: str = "D65") -> dict:
+    """Full pipeline: reflectance spectrum → all color representations.
+
+    Returns dict with keys: X, Y, Z, x, y, Y_lum, R, G, B (0–255), L, a, b
+    """
+    X, Y, Z = spectrum_to_XYZ(R_lambda, wavelengths_nm, illuminant)
+    x, y, Yl = XYZ_to_xyY(X, Y, Z)
+    R8, G8, B8 = XYZ_to_sRGB(X, Y, Z)
+    L, a, b = XYZ_to_Lab(X, Y, Z)
+    return {"X": X, "Y": Y, "Z": Z, "x": x, "y": y, "Y_lum": Yl,
+            "R": R8, "G": G8, "B": B8, "L": L, "a": a, "b": b}
