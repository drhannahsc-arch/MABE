+"""
+optical/mie_scattering.py — Module 3: Lorenz-Mie Scattering
+
+Wraps miepython 3.x (efficiencies API) for single-sphere Mie efficiencies.
+
+API: miepython.efficiencies(m, d, lambda0, n_env=1.0)
+  m      = complex refractive index of sphere
+  d      = diameter (same units as lambda0)
+  lambda0= vacuum wavelength
+  n_env  = real refractive index of surrounding medium
+
+Returns: qext, qsca, qback, g
+
+Validation:
+  Rayleigh limit (D<<λ): Q_sca ∝ x⁴ ∝ λ⁻⁴
+  Geometric optics limit (D>>λ): Q_ext → 2
+"""
+
+import math
+import numpy as np
+import miepython
+
+from optical.refractive_index import n_complex
+
+
+def mie_efficiencies(diameter_nm: float, n_sphere: complex,
+                     n_medium: float, wavelength_nm: float) -> dict:
+    """Mie efficiencies for a single homogeneous sphere.
+
+    Args:
+        diameter_nm:   Sphere diameter in nm
+        n_sphere:      Complex refractive index of sphere
+        n_medium:      Real refractive index of surrounding medium
+        wavelength_nm: Vacuum wavelength in nm
+
+    Returns:
+        dict: Q_sca, Q_ext, Q_abs, Q_back, g, x
+    """
+    # miepython convention: m = n_sphere / n_medium (relative index)
+    # and lambda0 is vacuum wavelength; n_env handles the medium
+    m = n_sphere / complex(n_medium)
+
+    qext, qsca, qback, g = miepython.efficiencies(m, diameter_nm, wavelength_nm, n_medium)
+    qabs = max(0.0, qext - qsca)
+    x = math.pi * diameter_nm * n_medium / wavelength_nm
+
+    return {
+        "Q_sca":  float(qsca),
+        "Q_ext":  float(qext),
+        "Q_abs":  float(qabs),
+        "Q_back": float(qback),
+        "g":      float(g),
+        "x":      float(x),
+    }
+
+
+def mie_spectrum(diameter_nm: float, material: str, n_medium: float,
+                 wavelengths_nm: np.ndarray) -> dict:
+    """Mie efficiency spectra over a wavelength array."""
+    results = {k: np.zeros(len(wavelengths_nm))
+               for k in ("Q_sca", "Q_ext", "Q_abs", "Q_back", "g")}
+    results["wavelengths_nm"] = wavelengths_nm
+
+    for i, lam in enumerate(wavelengths_nm):
+        nc = n_complex(material, lam)
+        eff = mie_efficiencies(diameter_nm, nc, n_medium, lam)
+        for k in ("Q_sca", "Q_ext", "Q_abs", "Q_back", "g"):
+            results[k][i] = eff[k]
+
+    return results
