+"""
+optical/structure_factor.py — Module 5: Percus-Yevick Structure Factor
+
+Analytical hard-sphere S(q) via Ashcroft & Lekner 1966, Phys. Rev. 145:83.
+
+S(q) = 1 / (1 - n * C(q))
+where C(q) is the PY direct correlation function Fourier transform.
+
+Closed-form C(q) from Ashcroft-Lekner eq (3):
+  C(q) = -4π/q³ * [α(sin x - x cos x) + β(2x sin x - (x²-2)cos x - 2)/x
+                   + γ((4x³-24x)sin x - (x⁴-12x²+24)cos x + 24)/x³]
+where x = qD,  n = 6φ/(πD³),
+  α = (1+2φ)²/(1-φ)⁴
+  β = -3φ(2+φ)²/(2(1-φ)⁴)
+  γ = φα/2 = φ(1+2φ)²/(2(1-φ)⁴)
+
+Validation: S(q) peak at q_peak ≈ 2π/(1.22 D) for φ=0.64.
+Benchmark: Manoharan structural-color package peak positions ±2%.
+"""
+
+import math
+import numpy as np
+
+
+def _py_alpha_beta_gamma(phi: float) -> tuple:
+    """PY coefficients α, β, γ (Ashcroft-Lekner 1966)."""
+    denom = (1 - phi)**4
+    alpha = (1 + 2*phi)**2 / denom
+    beta  = -3*phi*(2 + phi)**2 / (2 * denom)
+    gamma =  phi * (1 + 2*phi)**2 / (2 * denom)
+    return alpha, beta, gamma
+
+
+def _C_q(q: float, diameter: float, phi: float) -> float:
+    """PY direct correlation function FT C(q), units nm³.
+
+    Ashcroft & Lekner 1966, Phys. Rev. 145:83, eq (3).
+    """
+    alpha, beta, gamma = _py_alpha_beta_gamma(phi)
+    x = q * diameter
+
+    if x < 1e-6:
+        # Taylor expansion as x→0: avoid 0/0
+        # C(0) = -4π/3 D³ (α/3 - β/6 + γ/30) ... use limit
+        return -4*math.pi/3 * diameter**3 * (alpha/3 + beta*(-1/4) + gamma*(-1/30))
+
+    S, C_ = math.sin(x), math.cos(x)
+
+    T1 = alpha * (S - x*C_)
+    T2 = beta  * (2*x*S - (x**2 - 2)*C_ - 2) / x
+    T3 = gamma * ((4*x**3 - 24*x)*S - (x**4 - 12*x**2 + 24)*C_ + 24) / x**3
+
+    return -4*math.pi / q**3 * (T1 + T2 + T3)
+
+
+def structure_factor_PY(q: float, diameter: float, packing_fraction: float) -> float:
+    """Percus-Yevick structure factor S(q) for hard spheres.
+
+    Args:
+        q:               Wavevector magnitude (nm⁻¹)
+        diameter:        Sphere diameter (nm)
+        packing_fraction: Volume fraction φ (0 < φ ≤ 0.64)
+
+    Returns:
+        S(q) ≥ 0
+    """
+    if q < 1e-10:
+        return (1 - packing_fraction)**4 / (1 + 2*packing_fraction)**2
+
+    rho   = 6 * packing_fraction / (math.pi * diameter**3)   # nm⁻³
+    c_hat = _C_q(q, diameter, packing_fraction)
+    denom = 1 - rho * c_hat
+    return max(0.0, 1.0 / denom) if abs(denom) > 1e-10 else 0.0
+
+
+def structure_factor_array(q_array: np.ndarray, diameter: float,
+                            packing_fraction: float) -> np.ndarray:
+    """Vectorised S(q) over a q array."""
+    return np.array([structure_factor_PY(q, diameter, packing_fraction)
+                     for q in q_array])
+
+
+def sq_peak(diameter: float, packing_fraction: float,
+            n_points: int = 800) -> dict:
+    """Find S(q) peak position, height, and FWHM.
+
+    Returns:
+        dict: q_peak (nm⁻¹), S_peak, FWHM (nm⁻¹), lam_peak_nm
+    """
+    q_min = 0.3 * 2*math.pi / diameter
+    q_max = 5.0 * 2*math.pi / diameter
+
+    q_arr = np.linspace(q_min, q_max, n_points)
+    s_arr = structure_factor_array(q_arr, diameter, packing_fraction)
+
+    i_peak = int(np.argmax(s_arr))
+    q_pk   = float(q_arr[i_peak])
+    s_pk   = float(s_arr[i_peak])
+
+    # FWHM (simple threshold crossing)
+    half = s_pk / 2
+    left_arr = s_arr[:i_peak]
+    right_arr = s_arr[i_peak:]
+    q_left  = q_arr[np.searchsorted(left_arr[::-1], half, side='left')]  if i_peak > 0 else q_arr[0]
+    ri      = np.searchsorted(right_arr, half, side='right') - 1
+    q_right = q_arr[i_peak + ri] if i_peak + ri < n_points else q_arr[-1]
+
+    lam_peak = 2 * math.pi / q_pk
+
+    return {"q_peak": q_pk, "S_peak": s_pk,
+            "FWHM": float(q_right - q_left),
+            "lam_peak_nm": lam_peak}
