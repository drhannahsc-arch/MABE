@@ -0,0 +1,261 @@
+"""
+optical/cie_color.py — Module 9: CIE 1931 Color Calculation
+
+Converts reflectance spectra to human-perceived color.
+
+CIE 1931 2° standard observer color matching functions (tabulated at 5 nm).
+D65 illuminant spectral power distribution.
+
+Functions:
+  spectrum_to_XYZ(R, wavelengths, illuminant)  → (X, Y, Z)
+  XYZ_to_xyY(X, Y, Z)                          → (x, y, Y)
+  XYZ_to_sRGB(X, Y, Z)                         → (R8, G8, B8)  0–255
+  XYZ_to_Lab(X, Y, Z)                          → (L*, a*, b*)
+  cie_delta_E(Lab1, Lab2)                       → ΔE (CIE76)
+
+Validation: flat R=1 under D65 → (x, y) = (0.3127, 0.3290) ±0.001
+
+Sources:
+  CIE 1931 CMFs: CIE publication 15:2004, Table 1 (Stiles & Burch 1959 fit)
+  D65 SPD: CIE publication 15:2004, Table 1
+  sRGB conversion: IEC 61966-2-1:1999
+"""
+
+import math
+import numpy as np
+from typing import Optional
+
+
+# ── CIE 1931 2° color matching functions (tabulated 360–780 nm, 5 nm steps) ──
+# Source: CIE 15:2004 Table 1 (Stiles-Burch 2° CMF, re-expressed for CIE 1931)
+# Format: (wavelength_nm, x_bar, y_bar, z_bar)
+_CIE_CMF_5NM = [
+    (360, 0.000129900, 0.000003917, 0.000606100),
+    (365, 0.000232100, 0.000006965, 0.001086000),
+    (370, 0.000414900, 0.000012390, 0.001946000),
+    (375, 0.000741600, 0.000022020, 0.003486000),
+    (380, 0.001368000, 0.000039000, 0.006450100),
+    (385, 0.002236000, 0.000064000, 0.010549900),
+    (390, 0.004243000, 0.000120000, 0.020050100),
+    (395, 0.007650000, 0.000217000, 0.036210000),
+    (400, 0.014310000, 0.000396000, 0.067850100),
+    (405, 0.023190000, 0.000640000, 0.110200000),
+    (410, 0.043510000, 0.001210000, 0.207400000),
+    (415, 0.077630000, 0.002180000, 0.371300000),
+    (420, 0.134380000, 0.004000000, 0.645600000),
+    (425, 0.214770000, 0.007300000, 1.039050100),
+    (430, 0.283900000, 0.011600000, 1.385600000),
+    (435, 0.328500000, 0.016840000, 1.622960000),
+    (440, 0.348280000, 0.023000000, 1.747060000),
+    (445, 0.348060000, 0.029800000, 1.782600000),
