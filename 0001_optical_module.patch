+"""
+optical/underlayer_coupling.py — Module 8: Underlayer Spectral Coupling
+
+Models light recycling between a photonic glass film and a spectral underlayer.
+
+Physics (incoherent multi-pass, geometric series):
+  R_total(λ) = R_film(λ) + T_film(λ)² × R_under(λ) / (1 - R_under(λ) × R_film_back(λ))
+
+where:
+  R_film(λ)      = photonic glass reflectance (Module 6)
+  T_film(λ)      = 1 - R_film(λ) - A_film(λ)  (transmittance through film)
+  R_under(λ)     = underlayer reflectance (Fresnel for opaque; Mie for diffuse)
+  R_film_back(λ) = back-surface Fresnel reflectance of film (≈ R_film for symmetric film)
+
+Novel prediction: Fe₂O₃ primer under a photonic glass produces a CIE red-shift
+because it suppresses blue/green recycled light while passing red.
+
+Underlayer materials:
+  carbon       — broadband absorber; R_under ≈ 0 → single-pass limit
+  Fe2O3        — spectrally selective; absorbs blue/green, reflects red
+  TiO2_rutile  — high-n broadband scatterer; R_under ≈ high, washes out color
+  ZnO          — high-n, slight UV absorption
+  white_bead   — diffuse SiO2 bead underlayer (approximate R_under ≈ 0.6 flat)
+
+References:
+  Iwata et al. 2017, Adv. Mater. 29:1605050 (black/white substrate comparison)
+  Katagiri et al. 2017, NPG Asia Mater. 9:e355 (carbon black concentration)
+"""
+
+import math
+import numpy as np
+
+from optical.refractive_index import n_complex
+
+
+def _fresnel_R_normal(n1: complex, n2: complex) -> float:
+    """Normal-incidence power reflectance at a flat interface."""
+    r = (n1 - n2) / (n1 + n2)
+    return abs(r)**2
+
+
+def underlayer_reflectance(material: str, wavelengths_nm: np.ndarray,
+                            film_n: float = 1.4) -> np.ndarray:
+    """Compute underlayer spectral reflectance R_under(λ).
+
+    For opaque absorbing underlayers: Fresnel at film/underlayer interface.
+    For 'white_bead': flat diffuse reflectance ~0.65.
+
+    Args:
+        material:      Underlayer material ('carbon', 'Fe2O3', 'TiO2_rutile',
+                       'ZnO', 'white_bead', 'air')
+        wavelengths_nm: Wavelength array
+        film_n:        Refractive index of the film in contact with underlayer
+
+    Returns:
+        R_under(λ) array
+    """
+    R = np.zeros(len(wavelengths_nm))
+    n1 = complex(film_n, 0.0)
+
+    for i, lam in enumerate(wavelengths_nm):
+        if material == "white_bead":
+            R[i] = 0.65   # diffuse flat reflectance approximation
+        elif material == "air":
+            R[i] = _fresnel_R_normal(n1, complex(1.0003, 0.0))
+        else:
+            n2 = n_complex(material, lam)
+            R[i] = _fresnel_R_normal(n1, n2)
+
+    return R
+
+
+def coupled_reflectance(
+    R_film: np.ndarray,
+    R_under: np.ndarray,
+    film_absorption_fraction: float = 0.0,
+) -> np.ndarray:
+    """Compute total reflectance including underlayer recycled light.
+
+    Geometric series (incoherent):
+      R_total = R_film + T² × R_under / (1 - R_under × R_film)
+    where T = (1 - R_film) × (1 - film_absorption_fraction)
+
+    Args:
+        R_film:                   Film reflectance array (0–1)
+        R_under:                  Underlayer reflectance array (0–1)
+        film_absorption_fraction: Fraction of transmitted light absorbed in film
+                                  on each pass (default 0 = no absorption)
+
+    Returns:
+        R_total(λ) array
+    """
+    T_film = (1 - R_film) * (1 - film_absorption_fraction)
+    denom  = 1 - R_under * R_film
+    denom  = np.where(np.abs(denom) < 1e-8, 1e-8, denom)
+    R_total = R_film + T_film**2 * R_under / denom
+    return np.clip(R_total, 0.0, 1.0)
+
+
+def photonic_glass_on_substrate(
+    R_film: np.ndarray,
+    wavelengths_nm: np.ndarray,
+    substrate: str = "carbon",
+    film_n: float = 1.35,
+    film_absorption_fraction: float = 0.0,
+) -> np.ndarray:
+    """Convenience: apply substrate spectral coupling to a photonic glass spectrum.
+
+    Args:
+        R_film:        Film reflectance from Module 6
+        wavelengths_nm: Wavelength array
+        substrate:     Underlayer material name
+        film_n:        Average film refractive index
+        film_absorption_fraction: Fractional absorption per pass
+
+    Returns:
+        R_total(λ) array (not normalised to 1)
+    """
+    R_under = underlayer_reflectance(substrate, wavelengths_nm, film_n=film_n)
+    return coupled_reflectance(R_film, R_under, film_absorption_fraction)
+
+
+# Convenience substrate list for iteration
+SUBSTRATE_MATERIALS = ["carbon", "Fe2O3", "TiO2_rutile", "ZnO", "white_bead", "air"]
