+"""
+optical/tmm.py — Module 7: Transfer Matrix Method for Multilayer Stacks
+
+Exact 1D solution for R(λ) and T(λ) of a planar multilayer stack.
+Handles both s- and p-polarisation at normal and oblique incidence.
+
+Layer stack format: list of (material_name_or_n, thickness_nm) tuples.
+  - First and last layers are semi-infinite (incidence/substrate media).
+  - Intermediate layers are finite-thickness films.
+  - material can be a string (Module 1 lookup) or a float (fixed n).
+
+Algorithm: standard 2×2 transfer matrix (Hecht, Born & Wolf).
+  For each layer: M_i = [[cos δ_i, -i sin δ_i / n_i],
+                          [-i n_i sin δ_i, cos δ_i]]
+  where δ_i = 2π n_i d_i cos θ_i / λ (phase thickness).
+
+Validation:
+  - Quarter-wave SiO₂/TiO₂ stack: stopband centre ±1 nm.
+  - Stopband width Δλ/λ₀ = (4/π) arcsin((n_H - n_L)/(n_H + n_L)) ± 0.1%.
+"""
+
+import math
+import cmath
+import numpy as np
+from typing import Union
+
+from optical.refractive_index import n_complex
+
+
+LayerSpec = tuple   # (material_or_n, thickness_nm)
+
+
+def _get_n(material: Union[str, float, complex], wavelength_nm: float) -> complex:
+    """Resolve material to complex refractive index."""
+    if isinstance(material, str):
+        return n_complex(material, wavelength_nm)
+    return complex(material)
+
+
+def tmm_reflectance(
+    layer_stack: list,
+    wavelength_nm: float,
+    angle_deg: float = 0.0,
+    polarization: str = "s",
+) -> tuple:
+    """Compute reflectance and transmittance at a single wavelength.
+
+    Args:
+        layer_stack:   List of (material, thickness_nm) tuples.
+                       First and last are semi-infinite (thickness ignored).
+        wavelength_nm: Wavelength in nm.
+        angle_deg:     Angle of incidence in degrees (0 = normal).
+        polarization:  's' or 'p'.
+
+    Returns:
+        (R, T) — power reflectance and transmittance (0–1).
+    """
+    theta0 = math.radians(angle_deg)
+    n0 = _get_n(layer_stack[0][0], wavelength_nm)
+    cos_theta0 = cmath.sqrt(1 - (n0 * math.sin(theta0))**2 / n0**2)
+
+    # Build transfer matrix
+    M = np.eye(2, dtype=complex)
+
+    for i, (mat, d_nm) in enumerate(layer_stack):
+        ni = _get_n(mat, wavelength_nm)
+
+        # Snell's law: n0 sin θ0 = ni sin θi
+        sin_theta_i = n0 * math.sin(theta0) / ni
+        cos_theta_i = cmath.sqrt(1 - sin_theta_i**2)
+
+        if i == 0 or i == len(layer_stack) - 1:
+            # Semi-infinite: no phase, no matrix multiply
+            continue
+
+        # Phase thickness
+        delta = 2 * math.pi * ni * cos_theta_i * d_nm / wavelength_nm
+
+        # Effective indices for s/p polarisation
+        if polarization.lower() == "s":
+            eta_i = ni * cos_theta_i
+        else:
+            eta_i = ni / cos_theta_i
+
+        cd = cmath.cos(delta)
+        sd = cmath.sin(delta)
+
+        if abs(eta_i) < 1e-15:
+            continue
+        Mi = np.array([[cd,              -1j * sd / eta_i],
+                       [-1j * eta_i * sd, cd              ]], dtype=complex)
+        M = M @ Mi
+
+    # Admittances of incidence and substrate media
+    n_in  = _get_n(layer_stack[0][0],  wavelength_nm)
+    n_sub = _get_n(layer_stack[-1][0], wavelength_nm)
+    sin_sub = n0 * math.sin(theta0) / n_sub
+    cos_sub = cmath.sqrt(1 - sin_sub**2)
+
+    if polarization.lower() == "s":
+        eta_in  = n_in  * cos_theta0
+        eta_sub = n_sub * cos_sub
+    else:
+        eta_in  = n_in  / cos_theta0 if abs(cos_theta0) > 1e-15 else complex(n_in.real, 0)
+        eta_sub = n_sub / cos_sub    if abs(cos_sub)    > 1e-15 else complex(n_sub.real, 0)
+
+    # Reflection coefficient r = (η_in M11 + η_in η_sub M12 - M21 - η_sub M22) /
+    #                             (η_in M11 + η_in η_sub M12 + M21 + η_sub M22)
+    m11, m12, m21, m22 = M[0,0], M[0,1], M[1,0], M[1,1]
+
+    denom = (eta_in * m11 + eta_in * eta_sub * m12 + m21 + eta_sub * m22)
+    if abs(denom) < 1e-15:
+        return 0.0, 0.0
+
+    r = (eta_in * m11 + eta_in * eta_sub * m12 - m21 - eta_sub * m22) / denom
+    t_amp = 2 * eta_in / denom
+
+    R = abs(r)**2
+    # Transmittance (accounting for different media)
+    T_factor = (eta_sub / eta_in).real if eta_in.real > 0 else 1.0
+    T = T_factor * abs(t_amp)**2
+    T = min(T, 1.0 - R)   # energy conservation clamp
+
+    return float(R), float(max(0.0, T))
+
+
+def tmm_spectrum(
+    layer_stack: list,
+    wavelengths_nm: np.ndarray,
+    angle_deg: float = 0.0,
+    polarization: str = "s",
+) -> tuple:
+    """Compute R(λ) and T(λ) spectra for a multilayer stack.
+
+    Returns:
+        (R_array, T_array) as numpy arrays
+    """
+    R_arr = np.zeros(len(wavelengths_nm))
+    T_arr = np.zeros(len(wavelengths_nm))
+    for i, lam in enumerate(wavelengths_nm):
+        R_arr[i], T_arr[i] = tmm_reflectance(layer_stack, lam, angle_deg, polarization)
+    return R_arr, T_arr
+
+
+def quarter_wave_stack(n_H: float, n_L: float, n_in: float, n_sub: float,
+                        center_wavelength_nm: float, n_pairs: int) -> list:
+    """Build a quarter-wave dielectric mirror layer stack.
+
+    Alternating high/low index layers, each λ₀/(4n) thick.
+    Stack: [medium | (H L)^n_pairs | H | substrate]
+
+    Returns:
+        layer_stack suitable for tmm_spectrum()
+    """
+    d_H = center_wavelength_nm / (4 * n_H)
+    d_L = center_wavelength_nm / (4 * n_L)
+
+    stack = [("air", 0)]   # semi-infinite incidence medium (n=1.0003, treated as air)
+    for _ in range(n_pairs):
+        stack.append((n_H, d_H))
+        stack.append((n_L, d_L))
+    stack.append((n_H, d_H))
+    stack.append((n_sub, 0))   # semi-infinite substrate
+    return stack
+
+
+def analytical_stopband_width(n_H: float, n_L: float,
+                               center_wavelength_nm: float) -> float:
+    """Analytical stopband width for quarter-wave stack.
+
+    Δλ/λ₀ = (4/π) × arcsin((n_H - n_L)/(n_H + n_L))
+
+    Returns:
+        Δλ in nm
+    """
+    ratio = (n_H - n_L) / (n_H + n_L)
+    return (4 / math.pi) * math.asin(ratio) * center_wavelength_nm
