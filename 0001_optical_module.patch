+    (760.0, 1.46, 3.80), (780.0, 1.61, 3.94), (800.0, 1.75, 4.08),
+]
+
+# Fe₂O₃ hematite — Querry 1985 (Palik compilation), ~400–700 nm
+# Significant absorption k; n ~2.9 with strong dispersion
+_FE2O3_TABULATED = [
+    (300, 2.87, 0.82), (320, 2.84, 0.59), (340, 2.78, 0.42),
+    (360, 2.77, 0.38), (380, 2.80, 0.37), (400, 2.84, 0.38),
+    (420, 2.90, 0.41), (440, 2.96, 0.41), (460, 3.01, 0.38),
+    (480, 3.02, 0.33), (500, 3.01, 0.25), (520, 2.95, 0.17),
+    (540, 2.86, 0.10), (560, 2.78, 0.062), (580, 2.72, 0.040),
+    (600, 2.68, 0.029), (620, 2.65, 0.022), (640, 2.63, 0.017),
+    (660, 2.62, 0.013), (680, 2.61, 0.010), (700, 2.60, 0.0082),
+]
+
+# Carbon (amorphous) — approximate broadband absorber
+# n ≈ 2.0, k ≈ 0.8 across visible (Palik vol 2; Jellison 1992)
+# Weakly dispersive; use constant approximation
+_CARBON_N = 2.0
+_CARBON_K = 0.8
+
+# Polydopamine — Mrózek 2022 (approximate visible range)
+# n ≈ 1.65–1.68, k ≈ 0.02–0.05 (brown-absorbing)
+_POLYDOPAMINE_N = 1.66
+_POLYDOPAMINE_K = 0.03
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Sellmeier evaluators
+# ══════════════════════════════════════════════════════════════════════════
+
+def _sellmeier(lam_um: float, terms: list) -> float:
+    """Evaluate Sellmeier equation n²(λ). λ in micrometers."""
+    n2 = 1.0
+    for B, C in terms:
+        n2 += B * lam_um**2 / (lam_um**2 - C)
+    return math.sqrt(max(n2, 1.0))
+
+
+def _sio2(lam_um: float) -> float:
+    return _sellmeier(lam_um, _SIO2_SELLMEIER)
+
+
+def _tio2_rutile(lam_nm: float) -> float:
+    """TiO₂ rutile ordinary ray — Devore 1951 (tabulated, interpolated)."""
+    tab = _TIO2_RUTILE_TAB
+    if lam_nm <= tab[0][0]: return tab[0][1]
+    if lam_nm >= tab[-1][0]: return tab[-1][1]
+    for i in range(len(tab)-1):
+        if tab[i][0] <= lam_nm <= tab[i+1][0]:
+            t = (lam_nm - tab[i][0]) / (tab[i+1][0] - tab[i][0])
+            return tab[i][1] + t*(tab[i+1][1]-tab[i][1])
+    return tab[-1][1]
+
+
+def _tio2_anatase(lam_um: float) -> float:
+    """TiO₂ anatase — approximate Sellmeier (Ribarsky/Palik).
+    Lower n than rutile; n ≈ 2.49 at 589 nm.
+    """
+    n2 = 1.0 + 3.7279 * lam_um**2 / (lam_um**2 - 0.05271**2)
+    return math.sqrt(max(n2, 1.0))
+
+
+def _polystyrene(lam_um: float) -> float:
+    """Polystyrene — Sultanova 2009.
+    n²-1 = 1.4435λ²/(λ²-0.020216²)
+    """
+    n2 = 1.0 + 1.4435 * lam_um**2 / (lam_um**2 - 0.020216**2)
+    return math.sqrt(max(n2, 1.0))
+
+
+def _zno(lam_um: float) -> float:
+    """ZnO ordinary ray — Bond 1965 (simplified 3-term)."""
+    return _sellmeier(lam_um, _ZNO_SELLMEIER)
+
+
+def _si3n4(lam_um: float) -> float:
+    """Si₃N₄ — Luke 2015."""
+    return _sellmeier(lam_um, _SI3N4_SELLMEIER)
+
+
+def _tabulated_interp(lam_nm: float, table: list) -> complex:
+    """Linear interpolation in tabulated (λ_nm, n, k) data."""
+    lams = [row[0] for row in table]
+    ns   = [row[1] for row in table]
+    ks   = [row[2] for row in table]
+
+    if lam_nm <= lams[0]:
+        return complex(ns[0], ks[0])
+    if lam_nm >= lams[-1]:
+        return complex(ns[-1], ks[-1])
+
+    for i in range(len(lams) - 1):
+        if lams[i] <= lam_nm <= lams[i+1]:
+            t = (lam_nm - lams[i]) / (lams[i+1] - lams[i])
+            n = ns[i] + t * (ns[i+1] - ns[i])
+            k = ks[i] + t * (ks[i+1] - ks[i])
+            return complex(n, k)
+    return complex(ns[-1], ks[-1])
+
+
+# ══════════════════════════════════════════════════════════════════════════
+# Public API
+# ══════════════════════════════════════════════════════════════════════════
+
+MATERIALS = {
+    "SiO2", "TiO2_rutile", "TiO2_anatase", "TiO2",
+    "polystyrene", "PS",
+    "ZnO", "Si3N4",
+    "Fe2O3", "carbon", "gold", "Au",
+    "water", "H2O",
+    "air", "vacuum",
+    "polydopamine",
+}
+
+
+def n_complex(material: str, wavelength_nm: float) -> complex:
+    """Return complex refractive index n + ik for a material at a wavelength.
+
+    Args:
+        material:      Material name (see MATERIALS set for valid names)
+        wavelength_nm: Wavelength in nanometers
+
+    Returns:
+        complex: real part = n (refractive index), imaginary part = k (extinction)
+
+    Note: k > 0 means the material is absorbing. The sign convention follows
+    the physics convention e^{i(kz - ωt)} where n_complex = n + ik for absorbers.
+    """
+    lam_um = wavelength_nm / 1000.0
+    mat = material.strip()
+
+    if mat in ("SiO2",):
+        return complex(_sio2(lam_um), 0.0)
+
+    if mat in ("TiO2_rutile", "TiO2"):
+        return complex(_tio2_rutile(wavelength_nm), 0.0)
+
+    if mat == "TiO2_anatase":
+        return complex(_tio2_anatase(lam_um), 0.0)
+
+    if mat in ("polystyrene", "PS"):
+        return complex(_polystyrene(lam_um), 0.0)
+
+    if mat == "ZnO":
+        return complex(_zno(lam_um), 0.0)
+
+    if mat == "Si3N4":
+        return complex(_si3n4(lam_um), 0.0)
+
+    if mat in ("Fe2O3",):
+        return _tabulated_interp(wavelength_nm, _FE2O3_TABULATED)
+
+    if mat in ("gold", "Au"):
+        return _tabulated_interp(wavelength_nm, _GOLD_TABULATED)
+
+    if mat == "carbon":
+        return complex(_CARBON_N, _CARBON_K)
+
+    if mat == "polydopamine":
+        return complex(_POLYDOPAMINE_N, _POLYDOPAMINE_K)
+
+    if mat in ("water", "H2O"):
+        # Hale & Querry 1973 — simple Cauchy approximation for visible
+        n = 1.3199 + 6878.0 / wavelength_nm**2 - 1.132e9 / wavelength_nm**4
+        return complex(n, 0.0)
+
+    if mat in ("air",):
+        return complex(1.0003, 0.0)
+
+    if mat == "vacuum":
+        return complex(1.0, 0.0)
+
+    raise ValueError(f"Unknown material: '{material}'. Available: {sorted(MATERIALS)}")
+
+
+def n_real(material: str, wavelength_nm: float) -> float:
+    """Return real part of refractive index."""
+    return n_complex(material, wavelength_nm).real
+
+
+def k_imag(material: str, wavelength_nm: float) -> float:
+    """Return extinction coefficient k (imaginary part)."""
+    return n_complex(material, wavelength_nm).imag
+
+
+def n_array(material: str, wavelengths_nm) -> np.ndarray:
+    """Vectorized real refractive index over array of wavelengths."""
+    return np.array([n_real(material, w) for w in wavelengths_nm])
+
+
+def nk_array(material: str, wavelengths_nm) -> tuple:
+    """Return (n_array, k_array) over wavelength array."""
+    nc = [n_complex(material, w) for w in wavelengths_nm]
+    return np.array([c.real for c in nc]), np.array([c.imag for c in nc])
