+"""
+tests/test_optical/test_optical_modules.py
+
+Validation tests for optical module (Modules 1–9).
+Pass/fail criteria per META2026_Code_Validation_Checklist.md
+"""
+
+import math
+import numpy as np
+import pytest
+
+
+class TestModule1RefractiveIndex:
+    def test_sio2_sodium_d_line(self):
+        from optical.refractive_index import n_real
+        n = n_real("SiO2", 589.3)
+        assert abs(n - 1.4585) < 0.002, f"SiO2 @ 589.3nm = {n:.4f}, want 1.4585 ±0.002"
+
+    def test_tio2_rutile_sodium_d(self):
+        from optical.refractive_index import n_real
+        n = n_real("TiO2", 589.0)
+        assert abs(n - 2.614) < 0.002, f"TiO2 @ 589nm = {n:.4f}, want 2.614 ±0.002"
+
+    def test_polystyrene_visible(self):
+        from optical.refractive_index import n_real
+        n = n_real("polystyrene", 589.3)
+        assert 1.55 < n < 1.62, f"PS n = {n:.4f}, expect 1.55–1.62"
+
+    def test_fe2o3_returns_complex(self):
+        from optical.refractive_index import n_complex
+        nc = n_complex("Fe2O3", 500)
+        assert nc.real > 2.0
+        assert nc.imag > 0.0
+
+    def test_unknown_material_raises(self):
+        from optical.refractive_index import n_real
+        with pytest.raises(ValueError):
+            n_real("unobtanium", 550)
+
+
+class TestModule2BraggOpal:
+    def test_bragg_physics_consistent(self):
+        """Physics: λ_peak scales linearly with D (fixed n)."""
+        from optical.bragg_opal import bragg_opal
+        p1 = bragg_opal(200, 1.45, 1.0)
+        p2 = bragg_opal(400, 1.45, 1.0)
+        assert abs(p2 / p1 - 2.0) < 0.01, "Bragg peak should scale linearly with D"
+
+    def test_bragg_reference_series(self):
+        """Predicted peaks within ±10 nm of physics-derived reference values."""
+        from optical.bragg_opal import bragg_opal, WATERHOUSE_DATA
+        from optical.refractive_index import n_real
+        n_s = n_real("SiO2", 550)
+        failures = []
+        for D, lam_ref in WATERHOUSE_DATA:
+            pred = bragg_opal(D, n_s, 1.0)
+            if abs(pred - lam_ref) > 10:
+                failures.append(f"D={D}: pred={pred:.0f} ref={lam_ref} diff={pred-lam_ref:+.0f}")
+        assert not failures, f"Bragg failures:\n" + "\n".join(failures)
+
+    def test_higher_n_medium_redshifts(self):
+        from optical.bragg_opal import bragg_opal
+        p_air   = bragg_opal(250, 1.45, 1.0)
+        p_water = bragg_opal(250, 1.45, 1.33)
+        assert p_water > p_air, "Higher n_medium should redshift Bragg peak"
+
+
+class TestModule3MieScattering:
+    def test_rayleigh_lambda_fourth(self):
+        """Q_sca ∝ λ⁻⁴ in Rayleigh limit (D << λ)."""
+        from optical.mie_scattering import mie_efficiencies
+        D = 30   # nm — deep Rayleigh regime
+        q400 = mie_efficiencies(D, complex(1.5, 0), 1.0, 400)["Q_sca"]
+        q800 = mie_efficiencies(D, complex(1.5, 0), 1.0, 800)["Q_sca"]
+        ratio = q400 / q800
+        expected = (800/400)**4   # = 16
+        assert abs(ratio / expected - 1) < 0.15, f"Rayleigh ratio={ratio:.2f}, expect~{expected}"
+
+    def test_geometric_optics_large_sphere(self):
+        """Q_ext → 2 for large spheres (x >> 1). Convergence is slow due to Mie ripple."""
+        from optical.mie_scattering import mie_efficiencies
+        # D=20000nm at λ=500nm → x ≈ 126; Q_ext oscillates around 2
+        eff = mie_efficiencies(20000, complex(1.5, 0), 1.0, 500)
+        assert 1.8 < eff["Q_ext"] < 2.3, f"Q_ext={eff['Q_ext']:.3f}, expect ~2 (slow convergence)"
+
+    def test_efficiencies_nonnegative(self):
+        from optical.mie_scattering import mie_efficiencies
+        from optical.refractive_index import n_complex
+        nc = n_complex("polystyrene", 550)
+        eff = mie_efficiencies(250, nc, 1.0, 550)
+        for k in ("Q_sca", "Q_ext", "Q_back"):
+            assert eff[k] >= 0, f"{k} is negative"
+
+
+class TestModule4CoreShellMie:
+    def test_zero_shell_matches_homogeneous(self):
+        """Shell thickness → 0 reproduces homogeneous sphere."""
+        from optical.core_shell_mie import mie_coated_efficiencies
+        from optical.mie_scattering import mie_efficiencies
+        from optical.refractive_index import n_complex
+        lam = 550
+        n_core = n_complex("SiO2", lam)
+        eff_coated = mie_coated_efficiencies(125, 125.001, n_core, complex(1.462,0), 1.0, lam)
+        eff_hom    = mie_efficiencies(250, n_core, 1.0, lam)
+        assert abs(eff_coated["Q_sca"] - eff_hom["Q_sca"]) < 0.02
+
+    def test_higher_n_shell_affects_spectrum(self):
+        """Higher-n shell changes Q_sca."""
+        from optical.core_shell_mie import mie_coated_efficiencies
+        n_core = complex(1.45, 0)
+        eff_low  = mie_coated_efficiencies(100, 110, n_core, complex(1.46, 0), 1.0, 500)
+        eff_high = mie_coated_efficiencies(100, 110, n_core, complex(2.0,  0), 1.0, 500)
+        assert abs(eff_low["Q_sca"] - eff_high["Q_sca"]) > 0.01
+
+
+class TestModule5StructureFactor:
+    def test_sq_positive(self):
+        from optical.structure_factor import structure_factor_PY
+        import numpy as np
+        q_arr = np.linspace(0.01, 0.2, 50)
+        for q in q_arr:
+            assert structure_factor_PY(q, 200, 0.55) >= 0
+
+    def test_peak_increases_with_phi(self):
+        """S(q) peak height should increase with packing fraction."""
+        from optical.structure_factor import sq_peak
+        s50 = sq_peak(200, 0.50)["S_peak"]
+        s64 = sq_peak(200, 0.64)["S_peak"]
+        assert s64 > s50, f"S_peak should increase with phi: {s50:.2f} vs {s64:.2f}"
+
+    def test_peak_scales_inversely_with_D(self):
+        """q_peak ∝ 1/D."""
+        from optical.structure_factor import sq_peak
+        r1 = sq_peak(200, 0.55)
+        r2 = sq_peak(400, 0.55)
+        ratio = r1["q_peak"] / r2["q_peak"]
+        assert abs(ratio - 2.0) < 0.05, f"q_peak ratio={ratio:.3f}, expect 2.0 ±5%"
+
+
+class TestModule6PhotonicGlass:
+    def test_peak_shifts_red_with_larger_D(self):
+        """Larger spheres → longer structural color peak."""
+        from optical.photonic_glass import photonic_glass_peak_wavelength
+        p1 = photonic_glass_peak_wavelength(200, "polystyrene", 1.0, 0.55)
+        p2 = photonic_glass_peak_wavelength(280, "polystyrene", 1.0, 0.55)
+        assert p2 > p1, f"Larger D should redshift: {p1:.0f} vs {p2:.0f}"
+
+    def test_two_magkiriadou_points(self):
+        """At least 2/6 Magkiriadou reference points within ±20 nm (provisional)."""
+        from optical.photonic_glass import photonic_glass_peak_wavelength, MAGKIRIADOU_DATA
+        passed = sum(
+            abs(photonic_glass_peak_wavelength(D, "polystyrene", 1.0, 0.55) - obs) <= 20
+            for D, obs, _ in MAGKIRIADOU_DATA
+        )
+        assert passed >= 2, f"Only {passed}/6 within ±20 nm; model needs calibration"
+
+    def test_absorber_suppresses_short_wavelengths(self):
+        """Adding carbon absorber shifts apparent peak redward."""
+        from optical.photonic_glass import photonic_glass_reflectance
+        wls = np.linspace(400, 700, 100)
+        R_clean = photonic_glass_reflectance(220, "polystyrene", 1.0, 0.55, wls)
+        R_abs   = photonic_glass_reflectance(220, "polystyrene", 1.0, 0.55, wls,
+                                              absorber_fraction=0.05)
+        # Both should have a peak; absorber version should have more relative red
+        assert R_abs is not None
+
+
+class TestModule7TMM:
+    def test_quarter_wave_centre(self):
+        """Quarter-wave stack stopband centre within ±5 nm of design wavelength."""
+        from optical.tmm import tmm_spectrum, quarter_wave_stack
+        from optical.refractive_index import n_real
+        lam0 = 550
+        n_H = n_real("TiO2", lam0); n_L = n_real("SiO2", lam0)
+        stack = quarter_wave_stack(n_H, n_L, 1.0, 1.52, lam0, 5)
+        wls = np.linspace(400, 800, 600)
+        R, _ = tmm_spectrum(stack, wls)
+        centre = wls[np.argmax(R)]
+        assert abs(centre - lam0) <= 5, f"Stopband centre={centre:.1f} nm, target={lam0}"
+
+    def test_zero_thickness_is_transparent(self):
+        """Single interface (no films) gives Fresnel R."""
+        from optical.tmm import tmm_reflectance
+        R, T = tmm_reflectance([("air", 0), ("SiO2", 0)], 550)
+        R_fresnel = ((1.0 - 1.458) / (1.0 + 1.458))**2
+        assert abs(R - R_fresnel) < 0.005
+
+    def test_energy_conservation(self):
+        """R + T ≤ 1 (absorption makes up remainder)."""
+        from optical.tmm import tmm_spectrum, quarter_wave_stack
+        from optical.refractive_index import n_real
+        lam0 = 550
+        n_H = n_real("TiO2", lam0); n_L = n_real("SiO2", lam0)
+        stack = quarter_wave_stack(n_H, n_L, 1.0, 1.52, lam0, 3)
+        wls = np.linspace(450, 650, 50)
+        R, T = tmm_spectrum(stack, wls)
+        assert np.all(R + T <= 1.01), "R + T > 1 violates energy conservation"
+
+
+class TestModule9CIE:
+    def test_white_point_D65(self):
+        """Flat R=1 under D65 → (x,y) = (0.3127, 0.3290) ±0.001."""
