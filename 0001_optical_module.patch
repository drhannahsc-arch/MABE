+def _interp_cmf(wavelengths_nm: np.ndarray) -> tuple:
+    """Interpolate CMFs to arbitrary wavelength array."""
+    x = np.interp(wavelengths_nm, _CMF_WLS, _CMF_XBAR, left=0, right=0)
+    y = np.interp(wavelengths_nm, _CMF_WLS, _CMF_YBAR, left=0, right=0)
+    z = np.interp(wavelengths_nm, _CMF_WLS, _CMF_ZBAR, left=0, right=0)
+    return x, y, z
