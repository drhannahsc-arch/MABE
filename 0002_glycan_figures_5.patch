+"""
+glycan/figures/generate_figures.py — MABE Glycan Poster Figures
+
+Generates all figures for the 9th Canadian Glycomics Symposium poster.
+
+Figures produced:
+  Fig 1: Scatter plot — ΔG_pred vs ΔG_obs (headline R² figure)
+  Fig 2: Selectivity bar chart — ConA vs Davis (opposite selectivity proof)
+  Fig 3: WGA oligomer avidity series (GlcNAc → tetrasaccharide)
+  Fig 4: G3-V panel — MABE ε_CH_pi vs MIT DFT attenuated values
+  Fig 5: Heatmap — all scaffolds × ligands (residual matrix)
+
+Usage:
+    python glycan/figures/generate_figures.py [--output-dir PATH]
+"""
+
+import sys, os
+import argparse
+import math
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../.."))
+
+import matplotlib
+matplotlib.use("Agg")  # non-interactive backend
+import matplotlib.pyplot as plt
+import matplotlib.patches as mpatches
+import numpy as np
+
+from glycan.scorer import GlycanScorer
+from glycan.contact_maps import SCAFFOLD_CONTACTS
+from glycan.g3v_mit_dft import run_g3v_validation, FALLBACK_DFT_KCAL, KCAL_TO_KJ, F_SOLV_CENTRAL, F_SOLV_MIN, F_SOLV_MAX
+
+# ── Style constants ──────────────────────────────────────────────────────
+SCAFFOLD_COLORS = {
+    "ConA":  "#2166ac",
+    "WGA":   "#4dac26",
+    "PNA":   "#d6604d",
+    "Gal3":  "#7b2d8b",
+    "Davis": "#e08214",
+}
+CONF_MARKERS = {"HIGH": "o", "MEDIUM": "s", "LOW": "^"}
+CONF_ALPHA   = {"HIGH": 1.0, "MEDIUM": 0.75, "LOW": 0.45}
+
+FONT_TITLE  = 13
+FONT_LABEL  = 11
+FONT_TICK   = 9
+FONT_ANNOT  = 8
+
+DPI = 180
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Figure 1: Scatter ΔG_pred vs ΔG_obs
+# ════════════════════════════════════════════════════════════════════════════
+
+def fig1_scatter(preds, output_dir):
+    fig, ax = plt.subplots(figsize=(5.5, 5.0))
+
+    xs, ys = [], []
+    for p in preds:
+        if p.dG_obs is None:
+            continue
+        color = SCAFFOLD_COLORS.get(p.scaffold, "#888")
+        marker = CONF_MARKERS.get(p.confidence, "o")
+        alpha = CONF_ALPHA.get(p.confidence, 0.6)
+        ax.scatter(p.dG_obs, p.dG_pred, c=color, marker=marker,
+                   alpha=alpha, s=60, edgecolors="white", linewidths=0.5, zorder=3)
+        xs.append(p.dG_obs); ys.append(p.dG_pred)
+
+    # Identity line
+    lo = min(xs + ys) - 1
+    hi = max(xs + ys) + 1
+    ax.plot([lo, hi], [lo, hi], "k--", lw=1.0, alpha=0.5, label="y = x", zorder=2)
+
+    # R² annotation
+    scorer = GlycanScorer()
+    stats_all = scorer.compute_r2(preds)
+    stats_hi  = scorer.compute_r2(preds, confidence_filter=["HIGH"])
+    ax.text(0.05, 0.95,
+            f"All: R² = {stats_all['r2']:.3f}  MAE = {stats_all['mae']:.2f} kJ/mol\n"
+            f"HIGH: R² = {stats_hi['r2']:.3f}  MAE = {stats_hi['mae']:.2f} kJ/mol",
+            transform=ax.transAxes, va="top", ha="left",
+            fontsize=FONT_ANNOT, family="monospace",
+            bbox=dict(boxstyle="round,pad=0.3", fc="white", ec="#ccc", alpha=0.9))
+
+    # Legend: scaffolds
+    scaffold_handles = [
+        mpatches.Patch(color=c, label=s) for s, c in SCAFFOLD_COLORS.items()
+    ]
+    conf_handles = [
+        plt.Line2D([0], [0], marker=CONF_MARKERS[c], color="gray",
+                   linestyle="none", markersize=6,
+                   alpha=CONF_ALPHA[c], label=c)
+        for c in ["HIGH", "MEDIUM", "LOW"]
+    ]
+    leg1 = ax.legend(handles=scaffold_handles, loc="lower right",
+                     fontsize=FONT_ANNOT, title="Scaffold", title_fontsize=FONT_ANNOT,
+                     framealpha=0.9)
+    ax.add_artist(leg1)
+    ax.legend(handles=conf_handles, loc="upper left",
+              fontsize=FONT_ANNOT, title="Confidence", title_fontsize=FONT_ANNOT,
+              framealpha=0.9)
+
+    ax.set_xlabel("ΔG$_{obs}$ (kJ/mol)", fontsize=FONT_LABEL)
+    ax.set_ylabel("ΔG$_{pred}$ (kJ/mol)", fontsize=FONT_LABEL)
+    ax.set_title("MABE Glycan: Predicted vs Observed ΔG$_{bind}$\n"
+                 "(v2.3 locked parameters, zero biological fitting)",
+                 fontsize=FONT_TITLE - 1)
+    ax.tick_params(labelsize=FONT_TICK)
+    ax.set_aspect("equal")
+    ax.grid(True, alpha=0.25, lw=0.5)
+
+    path = os.path.join(output_dir, "fig1_scatter.png")
+    fig.tight_layout()
+    fig.savefig(path, dpi=DPI)
+    plt.close(fig)
+    print(f"  [✓] Fig 1 → {path}")
+    return path
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Figure 2: ConA vs Davis selectivity (opposite selectivity proof)
+# ════════════════════════════════════════════════════════════════════════════
+
+def fig2_opposite_selectivity(preds, output_dir):
+    pred_map = {(p.scaffold, p.ligand): p for p in preds}
+
+    sugars = ["Man", "Glc", "Gal"]
+    cona_vals  = [pred_map.get(("ConA",  s), None) for s in sugars]
+    davis_vals = [pred_map.get(("Davis", s), None) for s in sugars]
+
+    fig, axes = plt.subplots(1, 2, figsize=(7.0, 4.2), sharey=False)
+
+    def _bar(ax, vals, color, scaffold):
+        labels = []
+        preds_v, obs_v = [], []
+        for s, p in zip(sugars, vals):
+            if p is None:
+                continue
+            labels.append(s)
+            preds_v.append(p.dG_pred)
+            obs_v.append(p.dG_obs)
+        x = np.arange(len(labels))
+        w = 0.32
+        bars_pred = ax.bar(x - w/2, preds_v, w, color=color, alpha=0.85,
+                           label="MABE pred", zorder=3)
+        bars_obs  = ax.bar(x + w/2, obs_v,   w, color=color, alpha=0.40,
+                           label="Observed", zorder=3, hatch="//", edgecolor=color)
+        ax.set_xticks(x); ax.set_xticklabels(labels, fontsize=FONT_LABEL)
+        ax.set_ylabel("ΔG$_{bind}$ (kJ/mol)", fontsize=FONT_LABEL)
+        ax.set_title(f"{scaffold}", fontsize=FONT_TITLE, color=color)
+        ax.tick_params(labelsize=FONT_TICK)
+        ax.legend(fontsize=FONT_ANNOT, framealpha=0.85)
+        ax.grid(axis="y", alpha=0.25, lw=0.5)
+        ax.set_ylim(min(preds_v + obs_v) - 2, 0)
+        # Annotate selectivity arrow
+        ymin_i = np.argmin(preds_v)
+        ax.annotate("", xy=(x[ymin_i], min(preds_v) - 0.5),
+                    xytext=(x[ymin_i], min(preds_v) - 1.5),
+                    arrowprops=dict(arrowstyle="->", color="black", lw=1.2))
+        ax.text(x[ymin_i], min(preds_v) - 1.7, f"preferred\n({labels[ymin_i]})",
+                ha="center", va="top", fontsize=FONT_ANNOT - 1)
+
+    _bar(axes[0], cona_vals,  SCAFFOLD_COLORS["ConA"],  "ConA")
+    _bar(axes[1], davis_vals, SCAFFOLD_COLORS["Davis"], "Davis (synthetic)")
+
+    fig.suptitle("Opposite Selectivity — Same Physics Parameters",
+                 fontsize=FONT_TITLE, fontweight="bold", y=1.01)
+    fig.text(0.5, -0.03,
+             "ConA (biological lectin) prefers Man;  Davis receptor (synthetic) prefers Glc.\n"
+             "Zero structural homology. Zero re-fitting. Same ε parameters.",
+             ha="center", fontsize=FONT_ANNOT, style="italic")
+
+    path = os.path.join(output_dir, "fig2_opposite_selectivity.png")
+    fig.tight_layout()
+    fig.savefig(path, dpi=DPI, bbox_inches="tight")
+    plt.close(fig)
+    print(f"  [✓] Fig 2 → {path}")
+    return path
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Figure 3: WGA avidity series
+# ════════════════════════════════════════════════════════════════════════════
+
+def fig3_wga_avidity(preds, output_dir):
+    wga_preds = [p for p in preds if p.scaffold == "WGA"]
+    wga_preds.sort(key=lambda p: len(p.ligand))
+
+    labels = [p.ligand for p in wga_preds]
+    pred_v = [p.dG_pred for p in wga_preds]
+    obs_v  = [p.dG_obs  for p in wga_preds]
+
+    fig, ax = plt.subplots(figsize=(5.5, 4.0))
+    x = np.arange(len(labels))
+
+    ax.plot(x, pred_v, "o-", color=SCAFFOLD_COLORS["WGA"], lw=2.0,
+            markersize=8, label="MABE pred", zorder=3)
+    ax.plot(x, obs_v,  "s--", color=SCAFFOLD_COLORS["WGA"], lw=1.5,
+            alpha=0.5, markersize=7, label="Observed (Bains 1992)", zorder=2)
+
+    for i, (p, o) in enumerate(zip(pred_v, obs_v)):
+        ax.annotate(f"{p:.1f}", (x[i], p), textcoords="offset points",
+                    xytext=(0, 8), ha="center", fontsize=FONT_ANNOT, color=SCAFFOLD_COLORS["WGA"])
+
+    ax.set_xticks(x)
+    ax.set_xticklabels(labels, fontsize=FONT_LABEL)
+    ax.set_ylabel("ΔG$_{bind}$ (kJ/mol)", fontsize=FONT_LABEL)
+    ax.set_title("WGA — GlcNAc Oligomer Avidity Series\n(subsite saturation plateau at n=3)",
+                 fontsize=FONT_TITLE - 1)
+    ax.legend(fontsize=FONT_ANNOT)
+    ax.grid(True, alpha=0.25, lw=0.5)
+    ax.tick_params(labelsize=FONT_TICK)
+
+    # Plateau annotation
+    ax.annotate("Plateau\n(subsite D: linker only)",
+                xy=(3, pred_v[-1]), xytext=(2.3, pred_v[-1] + 1.5),
+                fontsize=FONT_ANNOT - 1, color="#555",
+                arrowprops=dict(arrowstyle="->", color="#555", lw=0.8))
+
+    path = os.path.join(output_dir, "fig3_wga_avidity.png")
+    fig.tight_layout()
+    fig.savefig(path, dpi=DPI)
+    plt.close(fig)
+    print(f"  [✓] Fig 3 → {path}")
+    return path
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Figure 4: G3-V — MABE ε_CH_pi vs MIT DFT attenuated values
+# ════════════════════════════════════════════════════════════════════════════
+
+def fig4_g3v_panel(output_dir):
+    g3v_results = run_g3v_validation(verbose=False)
+    res_labels = [r.residue for r in g3v_results]
+
+    mabe_vals = [r.mabe_eps for r in g3v_results]
+    att_central = [r.attenuated_central for r in g3v_results]
+    att_min = [r.attenuated_min for r in g3v_results]
+    att_max = [r.attenuated_max for r in g3v_results]
+
+    fig, ax = plt.subplots(figsize=(5.5, 4.2))
+    x = np.arange(len(res_labels))
+
+    # Attenuated DFT range bars
+    for i, (lo, hi, c) in enumerate(zip(att_min, att_max, att_central)):
+        ax.fill_between([i - 0.3, i + 0.3], [lo, lo], [hi, hi],
+                        color="#aec7e8", alpha=0.6, zorder=2,
+                        label="DFT attenuated range" if i == 0 else "")
+        ax.plot([i - 0.3, i + 0.3], [c, c], "-", color="#1f77b4", lw=2.0, zorder=3,
+                label="DFT central (f=0.25)" if i == 0 else "")
+
+    # MABE values
+    ax.scatter(x, mabe_vals, color="#d62728", s=80, zorder=4,
+               label="MABE v2.3 ε$_{CH‐π}$", marker="D")
+
+    # PASS labels
+    for i, r in enumerate(g3v_results):
+        status = "PASS" if r.within_2x else "WARN"
+        color = "#2ca02c" if r.within_2x else "#ff7f0e"
+        ax.text(i, mabe_vals[i] - 0.25, status,
+                ha="center", va="top", fontsize=FONT_ANNOT,
+                color=color, fontweight="bold")
+
+    ax.set_xticks(x)
+    ax.set_xticklabels(res_labels, fontsize=FONT_LABEL + 1)
+    ax.set_ylabel("ε$_{CH‐π}$ (kJ/mol)", fontsize=FONT_LABEL)
+    ax.set_title("G3-V: MABE ε$_{CH‐π}$ vs MIT DFT\n"
+                 "(Keys et al. 2025; f$_{solv}$=0.25 attenuation)",
+                 fontsize=FONT_TITLE - 1)
+    ax.legend(fontsize=FONT_ANNOT, loc="lower right")
+    ax.grid(axis="y", alpha=0.25, lw=0.5)
+    ax.tick_params(labelsize=FONT_TICK)
+
+    ax.text(0.02, 0.04,
+            f"Attenuation: f$_{{solv}}$=[{F_SOLV_MIN},{F_SOLV_MAX}]\n"
+            f"(Asensio 2013; Waters 2002)",
+            transform=ax.transAxes, fontsize=FONT_ANNOT - 1,
+            va="bottom", color="#555")
+
+    path = os.path.join(output_dir, "fig4_g3v_comparison.png")
+    fig.tight_layout()
+    fig.savefig(path, dpi=DPI)
+    plt.close(fig)
+    print(f"  [✓] Fig 4 → {path}")
+    return path
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Figure 5: Heatmap — all scaffolds × ligands (residual)
+# ════════════════════════════════════════════════════════════════════════════
+
+def fig5_heatmap(preds, output_dir):
+    # Collect unique ligands and scaffolds
+    scaffolds = list(SCAFFOLD_CONTACTS.keys())
+    ligand_order = []
+    seen = set()
+    for scaffold in scaffolds:
+        for lig in SCAFFOLD_CONTACTS[scaffold]:
+            if lig not in seen:
+                ligand_order.append(lig)
+                seen.add(lig)
+
+    # Build residual matrix (NaN where not applicable)
+    pred_map = {(p.scaffold, p.ligand): p for p in preds}
+    matrix = np.full((len(scaffolds), len(ligand_order)), np.nan)
+    conf_matrix = np.full((len(scaffolds), len(ligand_order)), "", dtype=object)
+
+    for si, scaffold in enumerate(scaffolds):
+        for li, ligand in enumerate(ligand_order):
+            p = pred_map.get((scaffold, ligand))
+            if p is not None and p.residual is not None:
+                matrix[si, li] = p.residual
+                conf_matrix[si, li] = p.confidence
+
+    fig, ax = plt.subplots(figsize=(max(8, len(ligand_order) * 0.7), 3.5))
+
+    # Mask NaN
+    masked = np.ma.array(matrix, mask=np.isnan(matrix))
+    vmax = 6.0
+    im = ax.imshow(masked, cmap="RdBu_r", aspect="auto",
+                   vmin=-vmax, vmax=vmax)
+
+    # Annotate cells
+    for si in range(len(scaffolds)):
+        for li in range(len(ligand_order)):
+            val = matrix[si, li]
+            if not np.isnan(val):
+                conf = conf_matrix[si, li]
+                text = f"{val:+.1f}"
+                if conf == "LOW":
+                    text += "*"
+                alpha_t = 1.0 if conf == "HIGH" else 0.7
+                ax.text(li, si, text, ha="center", va="center",
+                        fontsize=FONT_ANNOT - 1, alpha=alpha_t,
+                        color="white" if abs(val) > 3 else "black")
+
+    ax.set_xticks(np.arange(len(ligand_order)))
+    ax.set_xticklabels(ligand_order, rotation=40, ha="right", fontsize=FONT_ANNOT)
+    ax.set_yticks(np.arange(len(scaffolds)))
+    ax.set_yticklabels(scaffolds, fontsize=FONT_LABEL)
+
+    cbar = fig.colorbar(im, ax=ax, fraction=0.03, pad=0.02)
+    cbar.set_label("Residual ΔG$_{pred}$ − ΔG$_{obs}$ (kJ/mol)", fontsize=FONT_ANNOT)
+
+    ax.set_title("Prediction Residuals — All Scaffolds × Ligands\n"
+                 "(*LOW confidence;  blank = not measured)",
+                 fontsize=FONT_TITLE - 1)
+
+    path = os.path.join(output_dir, "fig5_residual_heatmap.png")
+    fig.tight_layout()
+    fig.savefig(path, dpi=DPI)
+    plt.close(fig)
+    print(f"  [✓] Fig 5 → {path}")
+    return path
+
+
+# ════════════════════════════════════════════════════════════════════════════
+# Main
+# ════════════════════════════════════════════════════════════════════════════
+
+def generate_all(output_dir: str = "glycan/figures/output"):
+    os.makedirs(output_dir, exist_ok=True)
+    scorer = GlycanScorer()
+    preds = scorer.score_all()
+
+    stats = scorer.compute_r2(preds)
+    stats_hi = scorer.compute_r2(preds, confidence_filter=["HIGH"])
+    print(f"\n[Glycan scorer] n={stats['n']}  R²={stats['r2']:.3f}  "
+          f"MAE={stats['mae']:.2f}  RMSE={stats['rmse']:.2f}")
+    print(f"[HIGH only]     n={stats_hi['n']}  R²={stats_hi['r2']:.3f}  "
+          f"MAE={stats_hi['mae']:.2f}  RMSE={stats_hi['rmse']:.2f}\n")
+    print(f"Generating figures → {output_dir}/")
+
+    paths = []
+    paths.append(fig1_scatter(preds, output_dir))
+    paths.append(fig2_opposite_selectivity(preds, output_dir))
+    paths.append(fig3_wga_avidity(preds, output_dir))
+    paths.append(fig4_g3v_panel(output_dir))
+    paths.append(fig5_heatmap(preds, output_dir))
+    print(f"\nDone. {len(paths)} figures written.")
+    return paths
+
+
+if __name__ == "__main__":
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--output-dir", default="glycan/figures/output")
+    args = parser.parse_args()
+    generate_all(args.output_dir)
