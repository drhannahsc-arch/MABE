 K_DESOLV_NAC  = +8.5   # kJ/mol  N-acetyl burial [ESTIMATE v2.2]
 
+# NHAc-specific recognition energies
+# Source: Chervenak & Toone 1994 JACS 116:10533 — WGA NHAc thermodynamics
+#   dH(GlcNAc-WGA) - dH(Glc-WGA) ≈ -8 to -10 kJ/mol; attributed to NHAc arm engagement
+#   WGA PDB 2UVO: Tyr73 OH → NHAc C=O + backbone NH → NHAc C=O (2 H-bonds to NHAc)
+#   Single carbonyl contact only (mono): -4.5 kJ/mol
+#   Bidentate (NH donor + C=O acceptor simultaneously engaged): -9.5 kJ/mol
+# STATUS: PROVISIONAL v2.4 — pending direct calorimetric deconvolution
+# THRESHOLD: need EPS_NHAC < -6.1 kJ/mol for GlcNAc selectivity at C2 vs Glc
+EPS_NHAC_MONO       = -4.5   # kJ/mol  single H-bond to NHAc C=O [PROVISIONAL v2.4]
+EPS_NHAC_BIDENTATE  = -9.5   # kJ/mol  bidentate arm (NH + C=O) [PROVISIONAL v2.4]
+
+NHAC_EPS = {
+    "none":       0.0,
+    "mono":       EPS_NHAC_MONO,
+    "bidentate":  EPS_NHAC_BIDENTATE,
+}
+
 # Residue-type CH-pi dispatch
 CH_PI_EPS = {
     "Trp": EPS_CH_PI_TRP,
