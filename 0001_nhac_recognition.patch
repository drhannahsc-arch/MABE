 # ══════════════════════════════════════════════════════════════════════════
 
 def _score_pocket_sugar(pocket: PocketConfig, sugar: str) -> Optional[float]:
+    """Score a pocket against a specific sugar.
+
+    NHAc arm logic:
+      - nhac_arm != 'none' means the pocket has a C2-specific amide-recognition motif
+      - If sugar C2 == K_NAC → arm engages: apply NHAC_EPS bonus
+      - If sugar C2 == other OH type → arm does NOT engage (geometry mismatch);
+        no bonus added; n_HB at C2 is still possible via generic HB
+      - If pocket contacts C2 AND nhac_arm != 'none': n_HB count excludes C2
+        (the arm is the contact at C2, not a generic HB)
+    """
     pos_map = SUGAR_POSITIONS.get(sugar)
     if pos_map is None:
         return None
 
+    nhac_arm_active = pocket.nhac_arm != "none"
+    # NHAc arm only makes sense if C2 is in contacted positions
+    nhac_at_c2 = nhac_arm_active and "C2" in pocket.contacted_positions
+
     desolv = 0.0
-    n_contactable = 0
+    n_contactable_for_HB = 0
+
     for pos in pocket.contacted_positions:
         oh_type = pos_map.get(pos)
         if oh_type is None:
-            return None          # Sugar missing this carbon
+            return None   # Sugar missing this carbon
         desolv += K_DESOLV.get(oh_type, 0.0)
-        n_contactable += 1
+        # C2 with NHAc arm: the arm handles C2 contact, generic HB not counted here
+        if not (pos == "C2" and nhac_at_c2):
+            n_contactable_for_HB += 1
 
-    if pocket.n_HB > n_contactable:
+    if pocket.n_HB > n_contactable_for_HB:
         return None
     if pocket.n_CHP > _max_chp(sugar):
         return None
 
+    # NHAc arm contribution
+    nhac_bonus = 0.0
+    if nhac_at_c2:
+        c2_type = pos_map.get("C2")
+        if c2_type == "K_NAC":
+            nhac_bonus = NHAC_EPS[pocket.nhac_arm]
+        # else: arm present but sugar has OH at C2 → arm doesn't engage (bonus = 0)
+
     return (pocket.n_HB * EPS_HB_EFF
             + desolv
             + pocket.n_CHP * CH_PI_EPS.get(pocket.res_type, 0.0)
+            + nhac_bonus
             + pocket.n_linker * EPS_LINKER_NET)
 
 
